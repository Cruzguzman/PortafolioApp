---
// src/components/Proyectos.astro

const proyectos = [
    {
        num: "01",
        titulo: "API de Gestión Empresarial",
        descripcion: "Sistema REST completo para gestión de recursos empresariales con autenticación JWT, roles y permisos, documentación Swagger y cobertura de tests al 90%.",
        stack: ["Spring Boot", "PostgreSQL", "Docker", "JWT"],
        github: "#",
        demo: "#",
        featured: true,
    },
    {
        num: "02",
        titulo: "Microservicios E-Commerce",
        descripcion: "Arquitectura de microservicios para plataforma de comercio con Spring Cloud, Eureka, API Gateway y mensajería asíncrona con Kafka.",
        stack: ["Spring Cloud", "Kafka", "Redis", "K8s"],
        github: "#",
        demo: "#",
        featured: false,
    },
    {
        num: "03",
        titulo: "Dashboard de Monitoreo",
        descripcion: "Panel de monitoreo en tiempo real para métricas de aplicaciones usando Spring Actuator, Prometheus y Grafana integrado en pipeline CI/CD.",
        stack: ["Spring Actuator", "Prometheus", "Grafana"],
        github: "#",
        demo: "#",
        featured: false,
    },
];
---

<section id="proyectos" class="py-24 px-6 bg-navy-mid">
    <div class="max-w-5xl mx-auto">

        <p class="mono text-xs tracking-widest text-gold uppercase mb-4" data-aos="fade-up">03 — Proyectos</p>
        <h2 class="text-4xl md:text-5xl font-semibold text-cream mb-12 leading-tight"
            style="font-family:'Playfair Display',serif" data-aos="fade-up" data-aos-delay="100">
            Trabajo <em>destacado</em>
        </h2>

        <div class="grid md:grid-cols-3 gap-5">
            {proyectos.map((p, i) => (
                    <article
                            class={`card-hover bg-navy border border-gold-dim rounded p-6 flex flex-col gap-4 hover:-translate-y-1 transition-all duration-300 ${p.featured ? "md:col-span-2" : ""}`}
                            data-aos="fade-up"
                            data-aos-delay={i * 100}
                    >
                        <!-- Header -->
                        <div class="flex items-center justify-between">
                            <span class="mono text-xs text-gold tracking-widest">{p.num}</span>
                            <div class="flex gap-2">
                                <a href={p.github}
                                   class="mono text-xs text-gray border border-gold-dim px-2 py-1 rounded hover:text-gold hover:border-gold transition-all">
                                    GH
                                </a>
                                <a href={p.demo}
                                   class="mono text-xs text-gray border border-gold-dim px-2 py-1 rounded hover:text-gold hover:border-gold transition-all">
                                    ↗
                                </a>
                            </div>
                        </div>

                        <!-- Body -->
                        <h3 class="text-cream text-xl font-semibold leading-snug"
                            style="font-family:'Playfair Display',serif">
                            {p.titulo}
                        </h3>
                        <p class="text-gray text-sm leading-relaxed flex-1">{p.descripcion}</p>

                        <!-- Stack -->
                        <div class="flex flex-wrap gap-2">
                            {p.stack.map(tag => (
                                    <span class="mono text-xs text-gold bg-gold-subtle px-2.5 py-1 rounded">
                {tag}
              </span>
                            ))}
                        </div>
                    </article>
            ))}
        </div>

    </div>
</section>

<style>
    .border-gold-dim { border-color: rgba(201,168,76,0.15); }
    .bg-gold-subtle  { background-color: rgba(201,168,76,0.08); }
</style>
