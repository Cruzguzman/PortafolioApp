---
// src/components/Footer.astro

const nombre    = "Tu Nombre";
const ciudad    = "Ciudad de México";
const pais      = "México";
const direccion = "Colonia Centro, CDMX";
const mapSrc    = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3762.661339932626!2d-99.13320498467442!3d19.432607145059994!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1ff35f5bd1563%3A0x6c366f0e2de02ff7!2sZ%C3%B3calo%2C%20Centro%20Hist%C3%B3rico%20de%20la%20Cdad.%20de%20M%C3%A9xico!5e0!3m2!1ses!2smx!4v1680000000000!5m2!1ses!2smx";

const navegacion = [
    { label: "Inicio",      href: "#inicio" },
    { label: "Sobre mí",    href: "#sobre-mi" },
    { label: "Skills",      href: "#skills" },
    { label: "Proyectos",   href: "#proyectos" },
    { label: "Experiencia", href: "#experiencia" },
    { label: "Contacto",    href: "#contacto" },
];

const redes = [
    {
        label: "GitHub",
        href: "https://github.com/tuusuario",
        svg: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.34-3.369-1.34-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>`,
    },
    {
        label: "LinkedIn",
        href: "https://linkedin.com/in/tuperfil",
        svg: `<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    },
    {
        label: "Twitter / X",
        href: "https://twitter.com/tuusuario",
        svg: `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    },
    {
        label: "Email",
        href: "mailto:tu@email.com",
        svg: `<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>`,
    },
];
---

<footer class="footer">

    <div class="gold-line"></div>

    <!-- ZONA PRINCIPAL: 3 columnas -->
    <div class="zone-links">

        <!-- COL 1: Navegación -->
        <div class="col">
            <p class="col-title">Navegación</p>
            <ul class="nav-list">
                {navegacion.map(link => (
                        <li><a href={link.href}>{link.label}</a></li>
                ))}
            </ul>
        </div>

        <!-- COL 2: Redes sociales -->
        <div class="col">
            <p class="col-title">Redes sociales</p>
            <div class="socials">
                {redes.map(red => (
                        <a href={red.href} target="_blank" class="social-item" aria-label={red.label}>
                            <span class="social-icon" set:html={red.svg}></span>
                            <span class="social-label">{red.label}</span>
                        </a>
                ))}
            </div>
        </div>

        <!-- COL 3: Ubicación -->
        <div class="col">
            <p class="col-title">Ubicación</p>

            <!-- Tarjeta de ciudad -->
            <div class="location-card">
                <div class="location-info">
          <span class="pin-icon">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </span>
                    <div>
                        <span class="city">{ciudad}</span>
                        <span class="country">{pais}</span>
                        <span class="address">{direccion}</span>
                    </div>
                </div>
            </div>

            <!-- Mini mapa -->
            <div class="map-wrap">
                <iframe
                        src={mapSrc}
                        width="100%"
                        height="140"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Ubicación en el mapa"
                ></iframe>
                <div class="map-overlay"></div>
            </div>

        </div>

    </div>

    <!-- BOTTOM BAR -->
    <div class="zone-bottom">
        <p>© {new Date().getFullYear()} {nombre} — Todos los derechos reservados</p>
        <div class="status">
            <span class="dot-pulse"></span>
            Disponible para proyectos
        </div>
        <p>Construido con <span class="highlight">Astro</span> & <span class="highlight">Tailwind</span></p>
    </div>

</footer>

<style>
    .footer {
        width: 100%;
        background: #05080F;
        border-top: 1px solid rgba(201,168,76,0.15);
        position: relative;
        font-family: 'DM Sans', sans-serif;
    }

    .gold-line {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(to right, transparent, #C9A84C, transparent);
    }

    /* ZONA PRINCIPAL */
    .zone-links {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
        display: grid;
        grid-template-columns: 1fr 1fr 1.4fr;
        gap: 2.5rem;
        border-bottom: 1px solid rgba(201,168,76,0.15);
    }

    .col { display: flex; flex-direction: column; gap: 1rem; }

    .col-title {
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        color: #C9A84C;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }

    /* Nav list */
    .nav-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }
    .nav-list li a {
        font-family: 'DM Mono', monospace;
        font-size: 0.78rem;
        color: #9CA3AF;
        letter-spacing: 0.06em;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        transition: color 0.2s;
    }
    .nav-list li a::before {
        content: '';
        display: block;
        width: 14px; height: 1px;
        background: rgba(201,168,76,0.2);
        transition: width 0.25s, background 0.25s;
        flex-shrink: 0;
    }
    .nav-list li a:hover { color: #C9A84C; }
    .nav-list li a:hover::before { width: 22px; background: #C9A84C; }

    /* Redes */
    .socials { display: flex; flex-direction: column; gap: 0.55rem; }
    .social-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        transition: all 0.2s;
    }
    .social-item:hover .social-label { color: #C9A84C; }
    .social-item:hover .social-icon  { background: #C9A84C; color: #0A0F1E; border-color: #C9A84C; }
    .social-icon {
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid rgba(201,168,76,0.15);
        border-radius: 4px;
        color: #9CA3AF;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .social-label {
        font-family: 'DM Mono', monospace;
        font-size: 0.72rem;
        color: #9CA3AF;
        letter-spacing: 0.06em;
        transition: color 0.2s;
    }

    /* Tarjeta ubicación */
    .location-card {
        background: #0A0F1E;
        border: 1px solid rgba(201,168,76,0.15);
        border-radius: 6px;
        padding: 0.85rem 1rem;
        transition: border-color 0.2s;
    }
    .location-card:hover { border-color: rgba(201,168,76,0.35); }

    .location-info {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
    }
    .pin-icon {
        color: #C9A84C;
        margin-top: 2px;
        flex-shrink: 0;
    }
    .location-info > div {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }
    .city {
        font-family: 'Playfair Display', serif;
        font-size: 0.95rem;
        color: #F5F0E8;
        font-weight: 600;
    }
    .country {
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        color: #C9A84C;
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }
    .address {
        font-size: 0.75rem;
        color: #9CA3AF;
    }

    /* Mini mapa */
    .map-wrap {
        position: relative;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid rgba(201,168,76,0.15);
    }
    .map-wrap iframe {
        display: block;
        filter: grayscale(100%) invert(92%) contrast(83%) brightness(0.85) sepia(20%);
        transition: filter 0.3s;
    }
    .map-wrap:hover iframe {
        filter: grayscale(60%) invert(92%) contrast(83%) brightness(0.9) sepia(10%);
    }
    .map-overlay {
        position: absolute;
        inset: 0;
        border: 1px solid rgba(201,168,76,0.2);
        border-radius: 6px;
        pointer-events: none;
    }

    /* BOTTOM BAR */
    .zone-bottom {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .zone-bottom p {
        font-family: 'DM Mono', monospace;
        font-size: 0.68rem;
        color: #9CA3AF;
    }
    .highlight { color: #C9A84C; }

    .status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'DM Mono', monospace;
        font-size: 0.68rem;
        color: #9CA3AF;
    }
    .dot-pulse {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: #C9A84C;
        animation: pulse 2s infinite;
        flex-shrink: 0;
    }
    @keyframes pulse {
        0%,100% { opacity:1; transform:scale(1); }
        50%      { opacity:0.4; transform:scale(0.7); }
    }

    /* Responsive */
    @media (max-width: 768px) {
        .zone-links { grid-template-columns: 1fr 1fr; }
        .col:last-child { grid-column: span 2; }
    }
    @media (max-width: 480px) {
        .zone-links { grid-template-columns: 1fr; }
        .col:last-child { grid-column: span 1; }
        .zone-bottom { flex-direction: column; align-items: center; text-align: center; }
    }
</style>
