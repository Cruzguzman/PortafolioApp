---
// src/components/Certificaciones.astro

const certificaciones = [
    {
        titulo:   "Oracle Certified Professional",
        subtitulo:"Java SE 17 Developer",
        emisor:   "Oracle",
        anio:     "2023",
        estado:   "Vigente",
        icono:    "☕",
        color:    "#C9A84C",
        badge:    "OCP",
        credencial: "#",
    },
    {
        titulo:   "AWS Certified Developer",
        subtitulo:"Associate",
        emisor:   "Amazon Web Services",
        anio:     "2023",
        estado:   "Vigente",
        icono:    "☁️",
        color:    "#FF9900",
        badge:    "AWS",
        credencial: "#",
    },
    {
        titulo:   "Spring Professional",
        subtitulo:"Certified Spring Developer",
        emisor:   "VMware / Broadcom",
        anio:     "2022",
        estado:   "Vigente",
        icono:    "🍃",
        color:    "#6DB33F",
        badge:    "SPR",
        credencial: "#",
    },
    {
        titulo:   "Certified Kubernetes Administrator",
        subtitulo:"CKA",
        emisor:   "Cloud Native Computing Foundation",
        anio:     "2022",
        estado:   "Vigente",
        icono:    "☸️",
        color:    "#326CE5",
        badge:    "CKA",
        credencial: "#",
    },
    {
        titulo:   "Docker Certified Associate",
        subtitulo:"DCA",
        emisor:   "Docker Inc.",
        anio:     "2021",
        estado:   "Vigente",
        icono:    "🐳",
        color:    "#2496ED",
        badge:    "DCA",
        credencial: "#",
    },
    {
        titulo:   "Professional Scrum Master",
        subtitulo:"PSM I",
        emisor:   "Scrum.org",
        anio:     "2021",
        estado:   "Vigente",
        icono:    "🔄",
        color:    "#009FDA",
        badge:    "PSM",
        credencial: "#",
    },
];
---

<section id="certificaciones" class="py-24 px-6 bg-navy">
    <div class="max-w-5xl mx-auto">

        <p class="mono text-xs tracking-widest text-gold uppercase mb-4"
           data-aos="fade-up">
            05 — Certificaciones
        </p>
        <h2 class="section-title text-4xl md:text-5xl font-semibold text-cream mb-12 leading-tight"
            data-aos="fade-up" data-aos-delay="100">
            Credenciales <em>profesionales</em>
        </h2>

        <div class="certs-grid">
            {certificaciones.map((cert, i) => (
                    <article
                            class="cert-card"
                            data-aos="fade-up"
                            data-aos-delay={i * 80}
                            style={`--accent: ${cert.color}`}
                    >
                        <!-- Top accent line -->
                        <div class="cert-line"></div>

                        <!-- Header -->
                        <div class="cert-header">
                            <span class="cert-icon">{cert.icono}</span>
                            <span class="cert-badge">{cert.badge}</span>
                        </div>

                        <!-- Body -->
                        <div class="cert-body">
                            <h3 class="cert-titulo">{cert.titulo}</h3>
                            <p class="cert-subtitulo">{cert.subtitulo}</p>
                            <p class="cert-emisor">{cert.emisor}</p>
                        </div>

                        <!-- Footer -->
                        <div class="cert-footer">
                            <div class="cert-meta">
                                <span class="cert-anio">{cert.anio}</span>
                                <span class="cert-estado">{cert.estado}</span>
                            </div>
                            <a href={cert.credencial} target="_blank" class="cert-link">
                                Ver credencial
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/>
                                </svg>
                            </a>
                        </div>

                    </article>
            ))}
        </div>

    </div>
</section>

<style>
    em { color: #C9A84C; font-style: italic; font-family: 'Playfair Display', serif; }

    .section-title { font-family: 'Playfair Display', serif; }

    /* Grid */
    .certs-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    /* Card */
    .cert-card {
        background: #111827;
        border: 1px solid rgba(201,168,76,0.12);
        border-radius: 6px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        cursor: default;
    }
    .cert-card:hover {
        transform: translateY(-4px);
        border-color: rgba(201,168,76,0.35);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    /* Accent line top */
    .cert-line {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: var(--accent);
        opacity: 0.7;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s ease;
    }
    .cert-card:hover .cert-line { transform: scaleX(1); }

    /* Glow background */
    .cert-card::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 120px; height: 120px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--accent), transparent 70%);
        opacity: 0.05;
        transition: opacity 0.3s;
        pointer-events: none;
    }
    .cert-card:hover::before { opacity: 0.12; }

    /* Header */
    .cert-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .cert-icon { font-size: 1.75rem; line-height: 1; }
    .cert-badge {
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
        padding: 0.25rem 0.6rem;
        border-radius: 3px;
    }

    /* Body */
    .cert-body { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
    .cert-titulo {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 600;
        color: #F5F0E8;
        line-height: 1.3;
    }
    .cert-subtitulo {
        font-family: 'DM Mono', monospace;
        font-size: 0.72rem;
        color: var(--accent);
        letter-spacing: 0.05em;
    }
    .cert-emisor {
        font-size: 0.78rem;
        color: #6B7280;
        margin-top: 0.2rem;
    }

    /* Footer */
    .cert-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(201,168,76,0.1);
    }
    .cert-meta { display: flex; align-items: center; gap: 0.6rem; }
    .cert-anio {
        font-family: 'DM Mono', monospace;
        font-size: 0.68rem;
        color: #6B7280;
        letter-spacing: 0.08em;
    }
    .cert-estado {
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        color: #4ADE80;
        background: rgba(74,222,128,0.08);
        border: 1px solid rgba(74,222,128,0.2);
        padding: 0.15rem 0.5rem;
        border-radius: 99px;
        letter-spacing: 0.08em;
    }
    .cert-link {
        font-family: 'DM Mono', monospace;
        font-size: 0.68rem;
        color: #6B7280;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.2s;
    }
    .cert-link:hover { color: #C9A84C; }

    /* Responsive */
    @media (max-width: 900px) {
        .certs-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
        .certs-grid { grid-template-columns: 1fr; }
    }
</style>

