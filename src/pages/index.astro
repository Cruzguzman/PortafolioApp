---
// src/pages/index.astro
import Layout    from '../layouts/Layout.astro';
import Navbar    from '../components/Navbar.astro';
import Hero      from '../components/Hero.astro';
import SobreMi   from '../components/SobreMi.astro';
import Skills    from '../components/Skills.astro';
import Proyectos from '../components/Proyectos.astro';
import Experiencia from '../components/Experiencia.astro';
import Contacto from '../components/Contacto.astro';
import Footer      from '../components/Footer.astro';
import Certificaciones from '../components/Certificaciones.astro';
import Divider from '../components/Divider.astro';
---

<Layout title="Miguel Ángel Cruz Guzmán — Java & Spring Developer">
	<Navbar />
	<Hero />
	<Divider label="sobre mí"           from="navy"      to="navy-mid"  />
	<SobreMi />
	<Divider label="skills & tecnologías" from="navy-mid" to="navy-dark" />
	<Skills />
	<Divider label="proyectos destacados" from="navy-dark" to="navy-mid" />
	<Proyectos />
	<Divider label="trayectoria profesional" from="navy-mid" to="navy-dark" />
	<Experiencia />
	<Divider label="certificaciones"     from="navy-dark" to="navy-mid"  />
	<Certificaciones />
	<Divider label="contacto"            from="navy-mid"  to="navy" />
	<Contacto />
	<Divider label="Ubicación"            from="navy-mid"  to="navy" />
	<Footer />
</Layout>
